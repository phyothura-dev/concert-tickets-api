NODE_ENV=production
PORT=3000
SQLITE_PATH=/app/data/ticket-reservation.sqlite
LOG_LEVEL=info
REDIS_URL=redis://redis:6379
# Keep empty in production; use "memory" only for local fallback.
RATE_LIMIT_FALLBACK=

# Public domain used by reverse proxy and OpenAPI server URL
SERVER_NAME=your-subdomain.int.yt
PUBLIC_API_BASE_URL=https://your-subdomain.int.yt/api/v1

# Sentry Cloud (SaaS)
SENTRY_DSN=https://<publicKey>@o<orgId>.ingest.sentry.io/<projectId>
SENTRY_ENVIRONMENT=production

